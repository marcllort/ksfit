# Project-specific deploy config for ~/own/.deploy/deploy.sh
# Host + user + ssh key live in ~/own/.deploy/defaults.conf.

PROJECT_NAME=stride
SERVER_PATH=/opt/stride
# Two processes in one container: web :3000, backend API :3001. Caddy splits
# / → web and /api → backend. Healthcheck hits the backend liveness probe.
APP_PORT=3000
HEALTHCHECK_PATH=/api/healthz
