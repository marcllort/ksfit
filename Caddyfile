# Caddyfile for Stride — LAN-only, trusted local HTTPS (host-installed Caddy).
#
# Serves https://treadmill.home with a cert from Caddy's internal CA. Splits
# the front door: /api/* → the backend (Hono on :3001), everything else → the
# Next.js web app (:3000). Both bind to loopback; only Caddy is on the LAN.
# See docs/DEPLOY.md.

treadmill.home {
	tls internal
	encode zstd gzip

	# Backend API — strip /api so the backend sees /v1/... at its root.
	handle_path /api/* {
		reverse_proxy 127.0.0.1:3001
	}

	# Web app.
	handle {
		reverse_proxy 127.0.0.1:3000
	}
}
