# Caddyfile for the sibling-container deployment (docker compose --profile proxy).
#
# Same as the host Caddyfile, but proxies to the app over the compose network
# (service name `ksfit`, internal port 3000) instead of the host loopback.
# See docs/DEPLOY.md → "Optional: run Caddy as a sibling container".

treadmill.home {
	tls internal
	encode zstd gzip
	reverse_proxy ksfit:3000
}
